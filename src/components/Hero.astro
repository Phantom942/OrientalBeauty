---
import { site } from '../config';
import Button from './Button.astro';
---

<section class="hero" aria-labelledby="hero-title">
  <div class="hero__content">
    <h1 id="hero-title" class="hero__title reveal" style="animation-delay: 0.2s">{site.name}</h1>
    <p class="hero__subtitle reveal" style="animation-delay: 0.3s">{site.tagline}</p>
    <p class="hero__desc reveal" style="animation-delay: 0.4s">{site.description}</p>
    <div class="reveal" style="animation-delay: 0.5s"><Button href="#contact">Prendre rendez-vous</Button></div>
  </div>
</section>
