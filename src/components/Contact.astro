---
import { contact, links, location } from '../config';
---

<section class="section" id="contact" aria-labelledby="contact-title">
  <div class="container" data-animate>
    <header class="section-header" data-animate-stagger>
      <h2 id="contact-title" class="section-header__title">Contact</h2>
      <p>Oriental Beauty — Browlift et cire orientale à {location.city} ({location.department}). Prenez rendez-vous.</p>
    </header>
    <div class="contact-content">
      <div class="contact-info" data-animate-stagger>
        <p><strong>Adresse</strong><br />{contact.address}</p>
        <p><strong>Téléphone</strong><br /><a href={`tel:${contact.phone.replace(/\s/g, '')}`}>{contact.phone}</a> · <a href={links.whatsapp} target="_blank" rel="noopener noreferrer" aria-label="Contacter sur WhatsApp">WhatsApp</a></p>
        <p><strong>Email</strong><br /><a href={`mailto:${contact.email}`}>{contact.email}</a></p>
        <p><strong>Instagram</strong><br /><a href={links.instagram} target="_blank" rel="noopener noreferrer">@oriental_beauty94</a></p>
      </div>
      <div class="contact-info contact-info--cta" data-animate-stagger>
        <p class="contact-cta__text">Réservez en ligne en quelques clics, au moment qui vous convient.</p>
        <div class="contact-buttons">
          <a href={links.calendly} class="contact-btn contact-btn--calendly" target="_blank" rel="noopener noreferrer">
            <span class="contact-btn__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="4" width="18" height="18" rx="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </span>
            <span class="contact-btn__label">Réserver sur Calendly</span>
          </a>
          <a href={links.whatsapp} class="contact-btn contact-btn--whatsapp" target="_blank" rel="noopener noreferrer">
            <span class="contact-btn__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </span>
            <span class="contact-btn__label">Écrire sur WhatsApp</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
