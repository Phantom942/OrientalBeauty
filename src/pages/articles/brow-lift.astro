---
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const faqItems = [
  { q: "C'est quoi un brow lift ?", a: "Le brow lift (ou relooking sourcils) est une technique esthétique qui rehausse, structure et fixe les poils de l'arcade sourcilière pour leur donner une forme définie, sans pigment ni maquillage. Il agit uniquement sur les poils naturels — contrairement au microblading ou au tatouage, le brow lift ne modifie pas la peau. L'effet dure 6 à 8 semaines et convient aux sourcils fins, clairsemés ou aux poils rebelles." },
  { q: "Comment se déroule un brow lift ?", a: "Le brow lift repose sur trois étapes : rehausser les poils, les structurer selon la forme de l'arcade, puis les fixer avec un produit adapté (résine végétale ou solution type lamination). Les poils sont coiffés vers le haut puis gainés pour maintenir cette orientation. La tenue dépend du type de fixateur et de la nature du poil." },
  { q: "Combien de temps dure un brow lift ?", a: "L'effet du brow lift dure entre 6 et 8 semaines, selon le cycle de repousse. Un entretien tous les 2 mois permet de garder des sourcils soignés en continu." },
  { q: "Le brow lift c'est pour qui ?", a: "Le brow lift convient aux sourcils fins, clairsemés ou aux poils rebelles. Il redonne de la forme et du volume sans modifier la densité naturelle, et donne un regard plus ouvert." },
  { q: "Faut-il du maquillage avec un brow lift ?", a: "Non. Le brow lift ne nécessite aucun maquillage au quotidien. L'effet reste soigné et structuré en permanence, y compris après le sport ou la douche." },
  { q: "Quelle est la différence entre brow lift et lamination des sourcils ?", a: "Le brow lift et la lamination sont des techniques proches. La lamination utilise une solution de perming pour friser le poil vers le haut ; le brow lift privilégie le coiffage et la fixation. Les deux offrent un effet durable de 6 à 8 semaines." },
  { q: "Faut-il un entretien entre deux séances de brow lift ?", a: "Un brossage quotidien avec une brosse à sourcils suffit entre deux rendez-vous. Aucun produit particulier n'est requis." },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(({ q, a }) => ({
    "@type": "Question",
    "name": q,
    "acceptedAnswer": { "@type": "Answer", "text": a },
  })),
};
---

<ArticleLayout
  title="Qu'est-ce que le brow lift ? Mise en beauté des sourcils sans maquillage"
  description="Le brow lift structure et fixe vos sourcils pour un regard naturel et harmonieux. Effet durable 6 à 8 semaines. Technique expliquée par Oriental Beauty à Créteil (94)."
>
  <Header />
  <main id="main">
    <article class="article">
      <div class="article__container">
        <a href="/articles/" class="article__back">← Tous les articles</a>
        <header class="article__header">
          <h1 class="article__title">Qu'est-ce que le brow lift ? Mise en beauté des sourcils sans maquillage</h1>
          <p class="article__lead">Technique de coiffage et de fixation des poils de l'arcade sourcilière, dont le principe repose sur la tenue prolongée de la forme sans recours au maquillage.</p>
        </header>
        <div class="article__content">
          <section class="qa-list" aria-label="Questions et réponses sur le brow lift">
            {faqItems.map(({ q, a }) => (
              <article class="qa-block">
                <h2 class="qa-block__question">{q}</h2>
                <div class="qa-block__answer">
                  <p>{a}</p>
                </div>
              </article>
            ))}
          </section>

          <p class="article__related">
            Pour l'épilation des sourcils ou du duvet du visage, la <a href="/articles/cire-orientale/">cire orientale</a> est une option souvent privilégiée pour sa composition naturelle et sa tolérance sur les zones sensibles.
          </p>

          <p class="article__cta">
            <a href="/#contact">Réserver un brow lift à Créteil</a>
          </p>
        </div>
      </div>
    </article>
  </main>
  <Footer />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>
</ArticleLayout>
